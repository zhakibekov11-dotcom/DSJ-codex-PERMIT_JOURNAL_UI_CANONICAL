NODE_ENV=development
# Override these per deployment. Production and ABTEST-A must not share the
# same public URLs if they are supposed to be isolated.
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
# Optional explicit CORS origin. Defaults to APP_URL when omitted.
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dsj
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
COOKIE_NAME=dsj_session
FIELD_ENCRYPTION_KEY=replace-with-32-plus-random-characters
FIELD_HASH_PEPPER=replace-with-a-separate-32-plus-random-characters
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Signing provider selection for local development. Keep this explicit; unset config disables signing.
SIGNING_PROVIDER=MOCK_NCALAYER
# Local DSJ bridge URL for NCALayer integration.
NCALAYER_BRIDGE_URL=http://127.0.0.1:13580
# Timeout for local bridge health/sign requests in milliseconds.
NCALAYER_BRIDGE_TIMEOUT_MS=15000
# Enables extra UI copy and NCALayer test-signer selection when provider=NCALAYER.
SIGNING_TEST_MODE=true
# Keep the public invite mock-sign flow disabled unless you are explicitly
# testing that local-only path outside production.
ALLOW_PUBLIC_INVITE_MOCK_SIGNING=false
# Planned generic signing/session settings. The current code still reads
# SIGNING_PROVIDER; these variables document the target legal signing contour.
SIGNING_PROVIDER_DEFAULT=MOCK_PROVIDER
SIGNING_MOCK_ENABLED=true
SIGNING_REQUIRE_LEGAL_PROVIDER_IN_PROD=true
NCALAYER_ENABLED=true
EGOV_MOBILE_QR_ENABLED=false
EGOV_MOBILE_QR_BASE_URL=
EGOV_MOBILE_QR_CLIENT_ID=
EGOV_MOBILE_QR_CLIENT_SECRET=
EGOV_MOBILE_QR_CALLBACK_URL=
EGOV_MOBILE_QR_CALLBACK_SECRET=
EGOV_MOBILE_QR_ALLOW_LOCAL_CALLBACK_SIMULATION=false
EGOV_MOBILE_QR_TIMEOUT_SECONDS=300
SIGNING_SESSION_TTL_SECONDS=300
SIGNATURE_EVIDENCE_STORAGE_MODE=database
SIGNATURE_EVIDENCE_BUCKET=
SIGNATURE_HASH_ALGORITHM=SHA-256
# Destructive seed runs are blocked in production and should only be enabled for
# an intentional local reset against a disposable database.
SEED_ALLOW_DESTRUCTIVE_RESET=false
# Required only for an intentional local destructive seed run.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_COMPANY_ADMIN_EMAIL=
SEED_COMPANY_ADMIN_PASSWORD=

