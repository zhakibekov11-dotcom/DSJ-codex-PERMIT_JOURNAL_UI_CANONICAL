generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  SAFETY_ENGINEER
  EMPLOYEE_SIGNER
}

enum EmployeeStatus {
  active
  inactive
}

enum EmployeeKind {
  INTERNAL
  CONTRACTOR
}

enum BriefingType {
  INTRODUCTORY
  PRIMARY
  REPEATED
  UNSCHEDULED
  TARGETED
}

enum BriefingJournalKind {
  INTRODUCTORY
  WORKPLACE
}

enum BriefingStatus {
  DRAFT
  READY_FOR_SIGNING
  SIGNED
  ARCHIVED
}

enum EmployeeInstructionStatus {
  ASSIGNED
  OPENED
  ACKNOWLEDGED
  SIGNED
  OVERDUE
}

enum SignatureProvider {
  MOCK_NCALAYER
  NCALAYER
  MOCK_PROVIDER
  NCALAYER_PROVIDER
  EGOV_MOBILE_QR_PROVIDER
  SMART_BRIDGE_PROVIDER
  DIGITAL_ID_PROVIDER
}

enum SignatureStatus {
  PREPARED
  SIGNED
  VERIFIED
  FAILED
  REVOKED
}

enum SigningSessionStatus {
  CREATED
  QR_GENERATED
  WAITING_FOR_USER
  CALLBACK_RECEIVED
  SIGNATURE_RECEIVED
  VERIFYING
  COMPLETED
  EXPIRED
  FAILED
  CANCELLED
}

enum SigningDocumentType {
  BRIEFING_RECORD
  BRIEFING_JOURNAL_ENTRY
  EMPLOYEE_DOCUMENT
  PROTOCOL
  RESPONSIBILITY_ORDER
  WORK_PERMIT
}

enum SigningCallbackValidationStatus {
  RECEIVED
  AUTHENTICATED
  REJECTED
}

enum SigningCallbackProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum SignatureEvidenceVerificationStatus {
  PENDING
  PASS
  FAIL
  INDETERMINATE
}

enum ReminderType {
  REPEATED_BRIEFING_DUE
  REPEATED_BRIEFING_OVERDUE
  UNSIGNED_RECORD_PENDING
  SIGNING_LINK_INVITE
}

enum ReminderStatus {
  pending
  sent
  resolved
  failed
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationJobStatus {
  queued
  processing
  sent
  failed
  skipped
}

enum DocumentType {
  CERTIFICATE
  PROTOCOL
  STATEMENT
  COMPLETION_CONFIRMATION
  SAFETY_CERTIFICATE
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  EXPIRING
  EXPIRED
}

enum CompanyDocumentCategory {
  LOCAL_ACT
  ORDER
  INSTRUCTION
  JOURNAL
  TRAINING_CERTIFICATION
}

enum CompanyDocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SafetyCertificateStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
}

enum TrainingAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum CardRequestMode {
  EMPLOYEE
  REQUEST
}

enum CardRequestType {
  BIOT
  PTM
  PB
  PS
}

enum BiotDocumentKind {
  WORKER_CARD
  ITR_CERTIFICATE
}

enum CorrespondenceKind {
  LETTER
  COMMERCIAL_PROPOSAL
}

enum CorrespondenceStatus {
  DRAFT
  READY_TO_SEND
  PARTIALLY_SENT
  SENT
  ARCHIVED
}

enum CorrespondenceRecipientStatus {
  PENDING
  SENT
  FAILED
}

model Company {
  id               String            @id @default(cuid())
  name             String
  bin              String?           @unique
  industry         String?
  timezone         String            @default("Asia/Almaty")
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  departments      Department[]
  sites            Site[]
  contractorCompanies ContractorCompany[]
  employees        Employee[]
  briefingBatches  BriefingBatch[]
  briefingRecords  BriefingRecord[]
  employeeDocuments EmployeeDocument[]
  companyDocuments CompanyDocument[]
  safetyCertificates SafetyCertificate[]
  trainingPrograms  TrainingProgram[]
  trainingAssignments TrainingAssignment[]
  exams            Exam[]
  examAttempts     ExamAttempt[]
  signatures       Signature[]
  reminders        Reminder[]
  notificationJobs NotificationJob[]
  auditLogs        AuditLog[]
  cardRequests     CardGenerationRequest[]
  correspondences  Correspondence[]
}

model User {
  id                 String           @id @default(cuid())
  companyId          String?
  departmentId       String?
  siteId             String?
  email              String           @unique
  passwordHash       String
  fullName           String
  role               UserRole
  isActive           Boolean          @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  department         Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  site               Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  employee           Employee?
  instructedBriefing BriefingRecord[] @relation("InstructorBriefings")
  assignedTrainingAssignments TrainingAssignment[] @relation("TrainingAssigner")
  signatures         Signature[]      @relation("UserSignatures")
  signingSessions    SigningSession[] @relation("SigningSessionSignerUser")
  verifiedEmployeeDocuments EmployeeDocument[] @relation("EmployeeDocumentVerifier")
  auditLogs          AuditLog[]       @relation("ActorAuditLogs")
  notificationJobs   NotificationJob[] @relation("NotificationAssignee")
  createdCardRequests CardGenerationRequest[] @relation("CardRequestsCreated")
  createdCorrespondences Correspondence[] @relation("CorrespondenceCreatedBy")
  createdCompanyDocuments CompanyDocument[] @relation("CompanyDocumentsCreatedBy")

  @@index([companyId, role])
}

model Department {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  code            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  employees       Employee[]
  briefingRecords BriefingRecord[]
  protocols       Protocol[]
  responsibilityOrders ResponsibilityOrder[]
  responsibilityAppointments ResponsibilityAppointment[]

  @@unique([companyId, name])
}

model Site {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  location        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  employees       Employee[]
  briefingRecords BriefingRecord[]

  @@unique([companyId, name])
}

model Employee {
  id              String           @id @default(cuid())
  companyId       String
  departmentId    String?
  siteId          String?
  positionId      String?
  userId          String?          @unique
  contractorCompanyId String?
  fullName        String
  iinEncrypted    String
  iinHash         String
  iinLast4        String
  employeeNumber  String
  jobTitle        String
  jobTitleKz      String?
  photoDataUrl    String?          @db.Text
  photoFileName   String?
  email           String?
  phone           String?
  employeeKind    EmployeeKind     @default(INTERNAL)
  status          EmployeeStatus   @default(active)
  isArchived      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  site            Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  position        Position?        @relation(fields: [positionId], references: [id], onDelete: SetNull)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  contractorCompany ContractorCompany? @relation(fields: [contractorCompanyId], references: [id], onDelete: SetNull)
  briefingRecords BriefingRecord[]
  documents       EmployeeDocument[]
  safetyCertificates SafetyCertificate[]
  trainingAssignments TrainingAssignment[]
  examAttempts    ExamAttempt[]
  protocolLinks   ProtocolEmployee[]
  responsibilityAppointments ResponsibilityAppointment[]
  signatures      Signature[]      @relation("EmployeeSignatures")
  signingSessions SigningSession[] @relation("SigningSessionSignerEmployee")
  reminders       Reminder[]
  cardRequestItems CardGenerationRequestItem[]

  @@unique([companyId, iinHash])
  @@unique([companyId, employeeNumber])
  @@index([companyId, fullName])
  @@index([companyId, status])
}

model ContractorCompany {
  id            String     @id @default(cuid())
  companyId     String
  name          String
  bin           String?
  contactEmail  String?
  contactPhone  String?
  notes         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees     Employee[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model BriefingBatch {
  id              String           @id @default(cuid())
  companyId       String
  batchNumber     String
  participantCount Int             @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  records         BriefingRecord[]

  @@unique([companyId, batchNumber])
  @@index([companyId, createdAt])
}

model BriefingRecord {
  id               String          @id @default(cuid())
  companyId        String
  briefingBatchId  String?
  departmentId     String?
  siteId           String?
  employeeId       String
  instructorUserId String
  briefingType     BriefingType
  briefingDate     DateTime
  completionDueAt  DateTime?
  nextBriefingDueAt DateTime?
  topic            String
  notes            String?
  materialContent  String?
  materialFileName String?
  materialFileUrl  String?
  status           BriefingStatus  @default(DRAFT)
  employeeStatus   EmployeeInstructionStatus @default(ASSIGNED)
  openedAt         DateTime?
  acknowledgedAt   DateTime?
  documentNumber   String?
  documentHash     String?
  inviteToken      String?         @unique
  inviteTokenHash  String?         @unique
  inviteTokenExpiresAt DateTime?
  inviteSentAt     DateTime?
  registrationCompletedAt DateTime?
  signedAt         DateTime?
  archivedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  briefingBatch    BriefingBatch?  @relation(fields: [briefingBatchId], references: [id], onDelete: SetNull)
  department       Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  site             Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  employee         Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  instructor       User            @relation("InstructorBriefings", fields: [instructorUserId], references: [id], onDelete: Restrict)
  signatures       Signature[]
  reminders        Reminder[]
  notificationJobs NotificationJob[]
  auditLogs        AuditLog[]      @relation("BriefingAuditLogs")

  @@unique([companyId, documentNumber])
  @@index([companyId, status, briefingDate])
  @@index([companyId, employeeStatus, completionDueAt])
  @@index([companyId, briefingType, briefingDate])
  @@index([employeeId, briefingDate])
}

model EmployeeDocument {
  id                 String         @id @default(cuid())
  companyId          String
  employeeId         String
  trainingAssignmentId String?
  documentTypeDefinitionId String?
  documentEnvelopeId String?       @unique
  title              String
  documentNumber     String?
  documentType       DocumentType
  issueDate          DateTime
  expiryDate         DateTime?
  issuerName         String
  status             DocumentStatus @default(DRAFT)
  verificationStatus EmployeeDocumentVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedByUserId   String?
  verificationNotes  String?
  fileName           String?
  fileUrl            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee           Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingAssignment TrainingAssignment? @relation(fields: [trainingAssignmentId], references: [id], onDelete: SetNull)
  documentTypeDefinition ComplianceDocumentType? @relation(fields: [documentTypeDefinitionId], references: [id], onDelete: SetNull)
  documentEnvelope   DocumentEnvelope? @relation(fields: [documentEnvelopeId], references: [id], onDelete: SetNull)
  verifiedByUser     User?          @relation("EmployeeDocumentVerifier", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  safetyCertificate  SafetyCertificate?

  @@index([companyId, employeeId, issueDate])
  @@index([companyId, status, expiryDate])
  @@index([companyId, documentTypeDefinitionId])
  @@index([companyId, verificationStatus, expiryDate])
}

model CompanyDocument {
  id              String                 @id @default(cuid())
  companyId       String
  createdByUserId String
  category        CompanyDocumentCategory
  documentName    String
  title           String
  summary         String?
  body            String                 @db.Text
  issueDate       DateTime?
  status          CompanyDocumentStatus  @default(DRAFT)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  company         Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser   User                   @relation("CompanyDocumentsCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, category, updatedAt])
  @@index([companyId, status, updatedAt])
}

model SafetyCertificate {
  id                 String                  @id @default(cuid())
  companyId          String
  employeeId         String
  trainingAssignmentId String?
  documentId         String?                 @unique
  certificateNumber  String
  issueDate          DateTime
  expiryDate         DateTime
  issuerName         String
  status             SafetyCertificateStatus @default(ACTIVE)
  fileName           String?
  fileUrl            String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  company            Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee           Employee                @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingAssignment TrainingAssignment?     @relation(fields: [trainingAssignmentId], references: [id], onDelete: SetNull)
  document           EmployeeDocument?       @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([companyId, certificateNumber])
  @@index([companyId, employeeId, expiryDate])
  @@index([companyId, status, expiryDate])
}

model TrainingProgram {
  id                     String              @id @default(cuid())
  companyId              String
  title                  String
  description            String
  materialContent        String?
  materialFileName       String?
  materialFileUrl        String?
  videoUrl               String?
  issuerName             String?
  requiresExam           Boolean             @default(false)
  createsDocument        Boolean             @default(false)
  createsSafetyCertificate Boolean           @default(false)
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  company                Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments            TrainingAssignment[]
  exam                   Exam?

  @@unique([companyId, title])
  @@index([companyId, isActive])
}

model TrainingAssignment {
  id                 String                   @id @default(cuid())
  companyId          String
  employeeId         String
  trainingProgramId  String
  assignedByUserId   String?
  dueAt              DateTime?
  status             TrainingAssignmentStatus @default(ASSIGNED)
  progressPercent    Int                      @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  examPassedAt       DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee           Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  trainingProgram    TrainingProgram          @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  assignedByUser     User?                    @relation("TrainingAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  generatedDocuments EmployeeDocument[]
  generatedCertificates SafetyCertificate[]
  examAttempts       ExamAttempt[]
  cardRequestItems   CardGenerationRequestItem[]

  @@unique([employeeId, trainingProgramId])
  @@index([companyId, status, dueAt])
}

model Exam {
  id                String          @id @default(cuid())
  companyId         String
  trainingProgramId String          @unique
  title             String
  description       String?
  passingScore      Int
  maxAttempts       Int             @default(3)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  questions         ExamQuestion[]
  attempts          ExamAttempt[]

  @@index([companyId, isActive])
}

model ExamQuestion {
  id         String       @id @default(cuid())
  examId      String
  prompt      String
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  options     ExamOption[]

  @@index([examId, sortOrder])
}

model ExamOption {
  id         String       @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean      @default(false)
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  question   ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, sortOrder])
}

model ExamAttempt {
  id                 String            @id @default(cuid())
  companyId          String
  examId             String
  trainingAssignmentId String
  employeeId         String
  status             ExamAttemptStatus @default(IN_PROGRESS)
  score              Int?
  passed             Boolean?
  startedAt          DateTime          @default(now())
  submittedAt        DateTime?
  answers            Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exam               Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  trainingAssignment TrainingAssignment @relation(fields: [trainingAssignmentId], references: [id], onDelete: Cascade)
  employee           Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId, startedAt])
  @@index([trainingAssignmentId, createdAt])
}

model CardGenerationRequest {
  id               String             @id @default(cuid())
  companyId        String
  createdByUserId  String
  title            String
  certificateType  CardRequestType
  biotDocumentKind BiotDocumentKind   @default(WORKER_CARD)
  includeCard      Boolean            @default(true)
  includeProtocol  Boolean            @default(true)
  includeWitness   Boolean            @default(false)
  requestMode      CardRequestMode
  issueDate        DateTime
  seriesNumber     String
  trainingSubject  String
  requestCompanyRu String?
  requestCompanyKz String?
  itemsCount       Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser    User               @relation("CardRequestsCreated", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items            CardGenerationRequestItem[]

  @@index([companyId, createdAt])
  @@index([companyId, certificateType, issueDate])
}

model CardGenerationRequestItem {
  id                 String                @id @default(cuid())
  requestId          String
  employeeId         String?
  trainingAssignmentId String?
  fullName           String
  fullNameKz         String?
  issuedTo           String?
  positionRu         String?
  positionKz         String?
  workplaceRu        String?
  workplaceKz        String?
  photoDataUrl       String?               @db.Text
  photoFileName      String?
  certificateNumber  String
  protocolNumber     String
  witnessCertificateNumber String?
  witnessRegistrationNumber String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  request            CardGenerationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  employee           Employee?             @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  trainingAssignment TrainingAssignment?   @relation(fields: [trainingAssignmentId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@index([employeeId])
  @@index([trainingAssignmentId])
}

model Correspondence {
  id              String                @id @default(cuid())
  companyId       String
  createdByUserId String
  registryNumber  String
  title           String
  kind            CorrespondenceKind
  subject         String
  body            String                @db.Text
  status          CorrespondenceStatus  @default(DRAFT)
  sentAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser   User                  @relation("CorrespondenceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  recipients      CorrespondenceRecipient[]

  @@unique([companyId, registryNumber])
  @@index([companyId, kind, createdAt])
  @@index([companyId, status, updatedAt])
}

model CorrespondenceRecipient {
  id              String                        @id @default(cuid())
  correspondenceId String
  companyName     String
  contactName     String
  contactEmail    String?
  contactPosition String?
  status          CorrespondenceRecipientStatus @default(PENDING)
  sentAt          DateTime?
  lastError       String?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  correspondence  Correspondence                @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)

  @@index([correspondenceId, createdAt])
  @@index([status, sentAt])
}

model Signature {
  id               String            @id @default(cuid())
  companyId        String?
  organizationId   String?
  briefingRecordId String?
  briefingJournalEntryId String?
  documentEnvelopeId String?
  documentVersionId String?
  signerUserId     String?
  signerEmployeeId String?
  signerRole       String?
  provider         SignatureProvider
  status           SignatureStatus   @default(PREPARED)
  signerName       String
  signerIinMasked  String
  certificateSerial String
  certificateMetadataId String?
  documentHash     String
  signatureHash    String?
  signedAt         DateTime?
  verifiedAt       DateTime?
  ipAddress        String?
  userAgent        String?
  signingSessionId String?
  payload          Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  briefingRecord   BriefingRecord?   @relation(fields: [briefingRecordId], references: [id], onDelete: Cascade)
  briefingJournalEntry BriefingJournalEntry? @relation(fields: [briefingJournalEntryId], references: [id], onDelete: SetNull)
  documentEnvelope DocumentEnvelope? @relation("EnvelopeSignatures", fields: [documentEnvelopeId], references: [id], onDelete: SetNull)
  documentVersion  DocumentVersion?   @relation("VersionSignatures", fields: [documentVersionId], references: [id], onDelete: SetNull)
  certificateMetadata CertificateMetadata? @relation(fields: [certificateMetadataId], references: [id], onDelete: SetNull)
  signerUser       User?             @relation("UserSignatures", fields: [signerUserId], references: [id], onDelete: SetNull)
  signerEmployee   Employee?         @relation("EmployeeSignatures", fields: [signerEmployeeId], references: [id], onDelete: SetNull)
  signingSession   SigningSession?   @relation(fields: [signingSessionId], references: [id], onDelete: SetNull)
  verification     SignatureVerification?
  evidence         SignatureEvidence[]

  @@index([companyId, briefingRecordId])
  @@index([organizationId, documentEnvelopeId])
  @@index([signingSessionId])
}

model SigningSession {
  id                String               @id @default(cuid())
  organizationId    String
  documentType      SigningDocumentType
  documentId        String
  documentEnvelopeId String?
  documentVersionId String?
  signerUserId      String?
  signerEmployeeId  String?
  signerIinMasked   String?
  signerIinHash     String?
  provider          SignatureProvider
  status            SigningSessionStatus @default(CREATED)
  providerSessionId String?
  documentHash      String
  hashAlgorithm     String               @default("SHA-256")
  idempotencyKey    String?
  providerPublicJson Json?
  expiresAt         DateTime
  completedAt       DateTime?
  cancelledAt       DateTime?
  failureReason     String?
  correlationId     String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentEnvelope  DocumentEnvelope?    @relation(fields: [documentEnvelopeId], references: [id], onDelete: SetNull)
  documentVersion   DocumentVersion?     @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  signerUser        User?                @relation("SigningSessionSignerUser", fields: [signerUserId], references: [id], onDelete: SetNull)
  signerEmployee    Employee?            @relation("SigningSessionSignerEmployee", fields: [signerEmployeeId], references: [id], onDelete: SetNull)
  signatures        Signature[]
  evidence          SignatureEvidence[]
  callbackEvents    ProviderCallbackEvent[]

