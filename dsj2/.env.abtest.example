NODE_ENV=production

# Branch-specific public URLs.
APP_URL=https://abtest-a.example.com
API_URL=https://api-abtest-a.example.com
CORS_ORIGIN=https://abtest-a.example.com

# Use a separate database if you need real isolation from production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/dsj_abtest_a
REDIS_URL=redis://USER:PASSWORD@HOST:PORT

# Secrets must not be shared with production.
JWT_SECRET=replace-with-a-different-long-random-secret
FIELD_ENCRYPTION_KEY=replace-with-a-different-32-plus-random-characters
FIELD_HASH_PEPPER=replace-with-a-different-32-plus-random-characters
COOKIE_NAME=dsj_session

# Keep the rest aligned with the contour you actually want.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
SIGNING_PROVIDER=NCALAYER
NCALAYER_BRIDGE_URL=http://127.0.0.1:13580
NCALAYER_BRIDGE_TIMEOUT_MS=15000
SIGNING_TEST_MODE=false
ALLOW_PUBLIC_INVITE_MOCK_SIGNING=false
# Planned generic signing/session settings. Keep eGov disabled until the
# provider contract, callback validation, and evidence storage are implemented.
SIGNING_PROVIDER_DEFAULT=NCALAYER_PROVIDER
SIGNING_MOCK_ENABLED=false
SIGNING_REQUIRE_LEGAL_PROVIDER_IN_PROD=true
NCALAYER_ENABLED=true
EGOV_MOBILE_QR_ENABLED=false
EGOV_MOBILE_QR_BASE_URL=
EGOV_MOBILE_QR_CLIENT_ID=
EGOV_MOBILE_QR_CLIENT_SECRET=
EGOV_MOBILE_QR_CALLBACK_URL=
EGOV_MOBILE_QR_CALLBACK_SECRET=
EGOV_MOBILE_QR_ALLOW_LOCAL_CALLBACK_SIMULATION=false
EGOV_MOBILE_QR_TIMEOUT_SECONDS=300
SIGNING_SESSION_TTL_SECONDS=300
SIGNATURE_EVIDENCE_STORAGE_MODE=database
SIGNATURE_EVIDENCE_BUCKET=
SIGNATURE_HASH_ALGORITHM=SHA-256
SEED_ALLOW_DESTRUCTIVE_RESET=false

