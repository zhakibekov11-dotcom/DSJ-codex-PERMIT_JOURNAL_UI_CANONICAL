  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matrix          JobRequirementMatrix? @relation(fields: [matrixId], references: [id], onDelete: SetNull)
  matrixVersion   JobRequirementMatrixVersion? @relation(fields: [matrixVersionId], references: [id], onDelete: SetNull)
  trainingPlanVersion TrainingPlanVersion? @relation(fields: [trainingPlanVersionId], references: [id], onDelete: SetNull)
  briefingJournalEntry BriefingJournalEntry? @relation(fields: [briefingJournalEntryId], references: [id], onDelete: SetNull)
  protocol        Protocol? @relation(fields: [protocolId], references: [id], onDelete: SetNull)
  workPermit      WorkPermit? @relation(fields: [workPermitId], references: [id], onDelete: SetNull)

  @@index([organizationId, subjectType, subjectId, evaluatedAt])
  @@index([organizationId, status, evaluatedAt])
}
